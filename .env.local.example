# ============================================================
# Sunao RAG Chatbot – environment variables
# Copy to `.env.local` and fill in real values before running.
# ============================================================

# ---- Supabase ----
# Browser-safe (anon, RLS-restricted)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only (Service Role; bypasses RLS — never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- OpenAI ----
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ---- RAG tuning (defaults wired into lib/rag) ----
RAG_MATCH_THRESHOLD=0.5
RAG_MATCH_COUNT=5
RAG_RECENCY_WEIGHT=0.15
RAG_RECENCY_HALF_LIFE_DAYS=180
# Set to >= 1.01 to disable semantic cache (recommended for demos to avoid
# wrong-topic hits in narrow-domain Japanese queries). Drop to 0.97–0.99 once
# you have enough query variety to confirm true positives.
RAG_CACHE_SIMILARITY_THRESHOLD=1.01

# ---- Ingest pipeline (scripts/ingest only) ----
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxx
# Optional: Slack webhook for ingest job notifications
SLACK_WEBHOOK_URL=
